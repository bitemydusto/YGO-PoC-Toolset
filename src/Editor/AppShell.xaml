<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Editor.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Editor"
    xmlns:view ="clr-namespace:Editor.View"
    Title="Editor">

    <TabBar>
        <Tab Title="Cards" Route="cards">
            <ShellContent ContentTemplate="{DataTemplate view:CardViewer}" />
        </Tab>
        <Tab Title="Save" Route="save">
            <ShellContent ContentTemplate="{DataTemplate view:SaveViewer}" />
        </Tab>
    </TabBar>

</Shell>
